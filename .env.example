# OpenRouter API Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openrouter/free
OPENROUTER_MODELS=openrouter/free,openai/gpt-4.1-mini,google/gemma-4-31b-it:free
OPENROUTER_ROTATE_MODELS=true

# For package generation
OPENAI_API_KEY=your_key_here

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Application Configuration
APP_TITLE=PAIPI - AI-Powered PyPI Search
APP_DESCRIPTION=PyPI search powered by AI's knowledge of Python packages
